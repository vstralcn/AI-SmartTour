# 可选：复制为 .env 后按需调整。无 .env 文件也可直接启动。
BACKEND_PORT=8000
TOURIST_PORT=3000
ADMIN_PORT=3001
DIGITAL_HUMAN_PORT=8001

POSTGRES_PASSWORD=smarttour

# 管理后台必须配置。ADMIN_TOKEN_SECRET 请使用至少 32 位随机字符串。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_TOKEN_SECRET=
ADMIN_TOKEN_TTL_MINUTES=480

# 逗号分隔；容器内前端通过同源代理访问，以下值用于本地 Vite 开发。
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# 留空时使用本地可信检索回答，不调用外部大模型。
LLM_API_KEY=
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# 讯飞虚拟人 Web SDK（六项均来自「交互平台 - 接口服务」，上线前替换为真实值）。
# 全部留空则前端自动降级回 VRM 数字人，不影响其余功能。
# 注意：API_SECRET 仅后端用于签名；API_KEY 会编码在短期签名 URL 中。
XF_AVATAR_APP_ID=
XF_AVATAR_API_KEY=
XF_AVATAR_API_SECRET=
XF_AVATAR_SCENE_ID=
XF_AVATAR_AVATAR_ID=
XF_AVATAR_VCN=
XF_AVATAR_SERVER_URL=wss://avatar.cn-huadong-1.xf-yun.com/v1/interact
